# ──────────────────────────────────────────────────────────────────────────────
# Amenity Screen Format Detector — environment configuration
# Copy this file to .env and fill in the values before starting the stack.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full SQLAlchemy connection URL for PostgreSQL.
# Default matches docker-compose.yml service credentials.
DATABASE_URL=postgresql://amenity:amenity@localhost:5432/amenitydb

# ── Security ──────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Change to a long random string in production.
SECRET_KEY=change-me

# ── AWS credentials (local dev only — use IAM role in production) ─────────────
# Fill these in for local development. Leave blank in production and attach
# an IAM role to the EC2/ECS instance instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── AWS Bedrock (Layer 2 AI) ──────────────────────────────────────────────────
# AWS region where Bedrock is available.
BEDROCK_REGION=us-east-1

# Bedrock model ID for no-match AI suggestions.
# Mistral Large 2 (multilingual) is the default.
BEDROCK_MODEL_ID=mistral.mistral-large-3-675b-instruct

# Bedrock API key (long-term token).
# Generate in the AWS console under Amazon Bedrock → API access → API keys.
BEDROCK_API_KEY=

# ── AI trigger mode ───────────────────────────────────────────────────────────
# off       — Layer 2 never fires (safe default for local dev)
# on        — Layer 2 fires on every true no-match
# residual  — also fires when a Standard result has unexplained leftover text
AI_TRIGGER_MODE=on

# Auto-apply confidence threshold (0.0–1.0).
# When set, AI suggestions at or above this score are auto-approved.
# Leave blank (default) to require human review for all AI suggestions.
# AI_AUTOAPPLY_CONFIDENCE=

# ── Redis (persistent Bedrock dedup cache) ────────────────────────────────────
# Connection URL for the Redis service.
# Default matches the docker-compose.yml redis service.
REDIS_URL=redis://redis:6379/0

# How many days to keep a cached Bedrock result before expiring it.
# Set lower if you expect AI model outputs to drift over time.
BEDROCK_CACHE_TTL_DAYS=30

# ── Batch processing ──────────────────────────────────────────────────────────
# Hard cap on rows per batch upload (prevents runaway jobs).
MAX_BATCH_ROWS=10000

# How many hours to retain completed job output files on disk.
JOB_TTL_HOURS=24

# ── Detection engine tuning ───────────────────────────────────────────────────
# Minimum token length for Track C prefix matching.
# Tokens shorter than this are skipped so short codes (XD, 3D) do not match
# inside concatenated strings.
TRACK_C_MIN_LEN=4

# Minimum Jaccard similarity score to accept a Track C circuit-name match.
CIRCUIT_MATCH_MIN_JACCARD=0.5

# ── Agentic title matching (Mode B) ──────────────────────────────────────────
# Set to true to replace the deterministic 6-stage pipeline with a Claude Code
# subprocess agent that performs web research + DB search autonomously.
# Keep false (default) for normal Mode A operation.
AGENTIC_TITLE_MATCH_ENABLED=false

# Route Mode B through AWS Bedrock (uses existing AWS_ACCESS_KEY_ID / BEDROCK_REGION creds).
# Set to false only if you want to use a direct Anthropic API key instead.
AGENTIC_USE_BEDROCK=true

# Bedrock cross-region inference profile ARN or Bedrock model ID.
# Must be a model available in your BEDROCK_REGION.
AGENTIC_CLAUDE_MODEL=us.anthropic.claude-sonnet-5

# Hard timeout (seconds) for a single agentic match call.
# Capped by MAX_TIMEOUT_MS (300s) in claude-sandbox/server.js.
AGENTIC_TIMEOUT_SECONDS=150

# TMDB read-only Bearer token — used only when DB results are ambiguous.
# Leave blank to skip TMDB; the agent will note the absence but still produce a result.
AGENTIC_TMDB_READ_TOKEN=

# Max number of in-flight sandbox calls for batch title matching (Mode B).
# Must stay equal to the celery-agentic-worker --concurrency flag in
# docker-compose.yml — these two numbers are coupled.
AGENTIC_BATCH_MAX_CONCURRENCY=2

# S3 bucket for batch upload/output storage — required because backend,
# celery-worker, and celery-agentic-worker are separate containers with no
# shared filesystem; a local /tmp path written by one is invisible to another.
AGENTIC_BATCH_S3_BUCKET=
AGENTIC_BATCH_S3_REGION=us-east-1

# Serper (google.serper.dev) API key — backs the movieweb MCP server's
# web_search/web_fetch tools inside claude-sandbox. Required because Bedrock
# has no built-in WebSearch tool; without this key the agent has no way to
# resolve obscure/foreign-language titles against external sources.
SERPER_API_KEY=

# ── Claude sandbox sidecar ────────────────────────────────────────────────────
# Internal URL of the claude-sandbox Docker service. Override only when running
# the sandbox on a non-default host or port.
CLAUDE_SANDBOX_URL=http://claude-sandbox:3100
